{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "vishal-logistics",
	"compatibility_date": "2025-03-01",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./dist"
	},
	"send_email": [
		{
			"name": "SEB"
		}
	],
	"vars": {
		"DESTINATION_EMAIL": "info@vishallogistics.in"
	}
}