{
  // "$schema": "node_modules/wrangler/config-schema.json",
  "name": "vishallogistics",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "compatibility_date": "2025-03-01",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
