---
// src/pages/privacy.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy Policy — Vishal Logistics Solutions">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 md:pt-36 md:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="relative max-w-[1400px] mx-auto px-5 lg:px-8">
      <p class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-4" data-reveal>Legal</p>
      <h1
        class="font-display font-extrabold text-white text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[1.0]"
        data-reveal
        style="--reveal-d:0.1s"
      >
        Privacy policy
      </h1>
      <p class="mt-5 text-white/40 text-lg max-w-[50ch]" data-reveal style="--reveal-d:0.2s">
        Last updated: March 2026
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="max-w-[780px] mx-auto px-5 lg:px-8">
      <div class="prose prose-navy max-w-none space-y-8" data-reveal>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">1. Information we collect</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            When you submit a quote request through our contact form, we collect your name, email address, phone number (optional), and message content. We do not collect any information automatically beyond standard server logs (IP address, browser type, pages visited).
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">2. How we use your information</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            We use the information you provide solely to respond to your enquiry and provide logistics services. We do not sell, rent, or share your personal data with third parties for marketing purposes.
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">3. Data storage</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            Your contact form submissions are processed via Web3Forms and delivered to our business email. We do not store your data in any database beyond what is necessary to respond to your request.
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">4. Cookies</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            This website does not use tracking cookies or third-party analytics services. No advertising or remarketing pixels are installed on this site.
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">5. Third-party services</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            We use the following third-party services: Google Fonts (for typography), Web3Forms (for form processing), and Cloudflare (for hosting and content delivery). Each of these services has its own privacy policy.
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">6. Your rights</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            You may request access to, correction of, or deletion of your personal data at any time by contacting us at
            <a href="mailto:vishallogistics22@gmail.com" class="text-copper hover:underline underline-offset-4">vishallogistics22@gmail.com</a>.
          </p>
        </div>

        <div>
          <h2 class="font-display font-bold text-navy text-xl mb-3">7. Changes to this policy</h2>
          <p class="text-offblack/60 text-sm leading-relaxed">
            We may update this privacy policy from time to time. Any changes will be posted on this page with an updated revision date.
          </p>
        </div>

        <div class="pt-6 border-t border-navy/8">
          <p class="text-offblack/40 text-sm">
            If you have any questions about this policy, please contact us at
            <a href="mailto:vishallogistics22@gmail.com" class="text-copper hover:underline underline-offset-4">vishallogistics22@gmail.com</a>
            or call
            <a href="tel:+918439312613" class="text-copper hover:underline underline-offset-4">+91 84393 12613</a>.
          </p>
        </div>

      </div>
    </div>
  </section>
</Layout>
