---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import CurrencyInput from '../components/CurrencyInput.astro';
import VolumetricCalculator from '../components/VolumetricCalculator.astro';
import ContainerCapacity from '../components/ContainerCapacity.astro';
import IncotermsGuide from '../components/IncotermsGuide.astro';
---

<Layout title="Logistics Tools — Vishal Logistics Solutions" description="Essential calculators and utilities for your freight and shipping planning.">
  <section class="pt-24 pb-10 px-5 lg:px-8 max-w-[1400px] mx-auto flex flex-col items-center justify-center">
    <div class="text-center mb-10" data-reveal>
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-copper/10 text-copper text-xs font-bold tracking-wide uppercase mb-3">
        <span class="w-1.5 h-1.5 rounded-full bg-copper animate-pulse"></span>
        Free Utilities
      </div>
      <h1 class="text-2xl md:text-3xl lg:text-4xl font-display font-bold text-navy mb-2 tracking-tight">Logistics Tools</h1>
      <p class="text-navy/70 max-w-2xl mx-auto text-sm">Real-time exchange rates and volumetric weight calculators to streamline your shipping.</p>
    </div>
    
    <div class="w-full max-w-6xl grid grid-cols-1 lg:grid-cols-2 gap-6 relative" data-reveal>
      
      <!-- Currency Converter Card -->
      <div class="w-full bg-white rounded-2xl shadow-xl shadow-navy/5 border border-navy/5 p-5 md:p-6 relative overflow-hidden h-full flex flex-col group/card">
        <!-- Background Decor -->
        <div class="absolute -top-24 -right-24 w-48 h-48 bg-copper/5 rounded-full blur-3xl pointer-events-none group-hover/card:bg-copper/10 transition-colors duration-500"></div>
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-navy/5 rounded-full blur-3xl pointer-events-none group-hover/card:bg-navy/10 transition-colors duration-500"></div>
        
        <div class="relative z-10 flex-grow">
          <div class="mb-6">
            <h2 class="text-xl font-display font-bold text-navy">Currency Converter</h2>
          </div>
          
          <!-- Converter Row -->
          <div class="grid grid-cols-1 gap-4 md:gap-5 items-end">
        <!-- From -->
        <CurrencyInput 
          idPrefix="from" 
          label="Amount" 
          defaultCurrencyCode="usd" 
          defaultCurrencyLabel="USD - US Dollar" 
        />
        
        <!-- Swap Button -->
        <button id="swap-btn" class="w-11 h-11 rounded-full bg-copper/10 text-copper flex items-center justify-center hover:bg-copper hover:text-white transition-all duration-300 mx-auto mb-1 active:scale-95 group border border-copper/10" aria-label="Swap currencies">
          <svg class="w-5 h-5 group-hover:rotate-180 transition-transform duration-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3L4 7l4 4"/><path d="M4 7h16"/><path d="M16 21l4-4-4-4"/><path d="M20 17H4"/></svg>
        </button>
        
        <!-- To -->
        <CurrencyInput 
          idPrefix="to" 
          label="Converted To" 
          defaultCurrencyCode="inr" 
          defaultCurrencyLabel="INR - Indian Rupee" 
          isReadonly={true} 
        />
          </div>
        </div>
        
        <!-- Rate Footer -->
        <div class="mt-auto pt-4 border-t border-navy/10 flex flex-col sm:flex-row items-center justify-between gap-2">
          <div>
            <p class="text-xs text-navy/50 font-medium mb-0.5 uppercase tracking-wide">Indicative Exchange Rate</p>
            <p id="rate-display" class="text-xl font-display font-bold text-copper tabular-nums transition-all">
              1 USD = <span class="inline-block w-20 h-5 bg-copper/10 rounded animate-pulse align-middle"></span> INR
            </p>
          </div>
          <div class="text-right">
            <p id="last-updated" class="text-xs font-medium text-navy/40 flex items-center justify-center sm:justify-end gap-1.5">
              <svg class="w-3.5 h-3.5 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
              Loading API...
            </p>
          </div>
        </div>
      </div>

      <!-- Volumetric Calculator Card -->
      <VolumetricCalculator />

      <!-- Container Capacity Card -->
      <ContainerCapacity />

      <!-- Incoterms Guide Card -->
      <IncotermsGuide />

    </div>
  </section>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const elFrom = document.getElementById('currency-from') as unknown as HTMLSelectElement;
    if (!elFrom) return;

    const elTo = document.getElementById('currency-to') as unknown as HTMLSelectElement;
    const elAmount = document.getElementById('amount-from') as unknown as HTMLInputElement;
    const elResult = document.getElementById('amount-to') as unknown as HTMLInputElement;
    const elSwap = document.getElementById('swap-btn');
    const elRateDisplay = document.getElementById('rate-display');
    const elLastUpdated = document.getElementById('last-updated');

    const API_PRIMARY = "https://cdn.jsdelivr.net/npm/@fawazahmed0/currency-api@latest/v1";
    const API_FALLBACK = "https://latest.currency-api.pages.dev/v1";

    let exchangeRates: Record<string, number> = {};

    async function fetchWithFallback(endpoint: string): Promise<Record<string, any>> {
      let primaryErr: unknown;
      try {
        const res = await fetch(`${API_PRIMARY}${endpoint}`);
        if (!res.ok) throw new Error('Primary API failed');
        return await res.json();
      } catch (err) {
        primaryErr = err;
      }
      try {
        console.warn('Primary API failed, using fallback:', primaryErr);
        const res = await fetch(`${API_FALLBACK}${endpoint}`);
        if (!res.ok) throw new Error('Fallback API failed');
        return await res.json();
      } catch (fallbackErr) {
        console.error('Both APIs failed. Primary:', primaryErr, 'Fallback:', fallbackErr);
        throw fallbackErr;
      }
    }

    async function loadCurrencies() {
      try {
        const data = await fetchWithFallback('/currencies.min.json');
        
        let optionsHtml = '';
        const common = ['usd', 'inr', 'eur', 'gbp', 'aud', 'cad', 'sgd', 'aed'];
        const sortedKeys = Object.keys(data).sort((a, b) => {
          const idxA = common.indexOf(a);
          const idxB = common.indexOf(b);
          if (idxA !== -1 && idxB !== -1) return idxA - idxB;
          if (idxA !== -1) return -1;
          if (idxB !== -1) return 1;
          return a.localeCompare(b);
        });

        sortedKeys.forEach(key => {
          if (key && data[key]) {
            optionsHtml += `<option value="${key}">${key.toUpperCase()} - ${data[key]}</option>`;
          }
        });
        
        elFrom.innerHTML = optionsHtml;
        elTo.innerHTML = optionsHtml;
        
        elFrom.value = 'usd';
        elTo.value = 'inr';
        
        await loadRates();
      } catch (err) {
        console.error('Failed to load currencies', err);
        if (elLastUpdated) {
          elLastUpdated.innerHTML = `<span class="text-red-500">Error loading data. Please reload.</span>`;
        }
      }
    }

    async function loadRates() {
      const from = elFrom.value;
      if (!from) return;
      
      try {
        if (elLastUpdated) elLastUpdated.innerHTML = `<svg class="w-3.5 h-3.5 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Fetching rates...`;
        
        const data = await fetchWithFallback(`/currencies/${from}.min.json`);
        exchangeRates = data[from];
        
        if (elLastUpdated && data.date) {
            elLastUpdated.innerHTML = `<svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Last updated: ${data.date}`;
        }
        
        calculate();
      } catch (err) {
        console.error('Failed to load rates', err);
        if (elLastUpdated) {
          elLastUpdated.innerHTML = `<span class="text-red-500">Failed to fetch rates.</span>`;
        }
      }
    }

    function calculate() {
      if (!exchangeRates || Object.keys(exchangeRates).length === 0) return;
      
      const rawValue = parseFloat(elAmount.value);
      const amount = isNaN(rawValue) ? 0 : rawValue;
      
      const to = elTo.value;
      const from = elFrom.value;
      const rate = exchangeRates[to];
      
      if (rate) {
        const result = amount * rate;
        elResult.value = result.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 6 });
        
        if (elRateDisplay) {
          elRateDisplay.textContent = `1 ${from.toUpperCase()} = ${rate.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 6 })} ${to.toUpperCase()}`;
        }
      }
    }

    // Attach Listeners
    elFrom.addEventListener('change', loadRates);
    elTo.addEventListener('change', calculate);
    elAmount.addEventListener('input', calculate);

    // Click-to-copy on the result field
    elResult.addEventListener('click', async () => {
      const val = elResult.value;
      if (!val || val === '0.00') return;
      try {
        await navigator.clipboard.writeText(val);
        // Brief green flash as confirmation
        elResult.classList.add('!border-green-400', '!text-green-600');
        setTimeout(() => elResult.classList.remove('!border-green-400', '!text-green-600'), 1000);
      } catch {
        // Fallback for browsers that block clipboard without user gesture
        elResult.select();
        document.execCommand('copy');
      }
    });
    
    if (elSwap) {
      elSwap.addEventListener('click', () => {
        const temp = elFrom.value;
        elFrom.value = elTo.value;
        elTo.value = temp;
        elSwap.classList.add('scale-90', 'bg-copper', 'text-white');
        setTimeout(() => elSwap.classList.remove('scale-90', 'bg-copper', 'text-white'), 200);
        
        loadRates();
      });
    }
    
    // Initial fetch
    loadCurrencies();
  });
</script>
