---
// src/pages/contact.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact Us — Vishal Logistics Solutions">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 md:pt-36 md:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="relative max-w-[1400px] mx-auto px-5 lg:px-8">
      <p class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-4" data-reveal>Contact</p>
      <h1
        class="font-display font-extrabold text-white text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[0.95]"
        data-reveal
        style="--reveal-d:0.1s"
      >
        Let's move your cargo.
      </h1>
      <p class="mt-5 text-white/40 text-lg max-w-[50ch]" data-reveal style="--reveal-d:0.2s">
        Tell us what you need shipped, and we will get back to you with a competitive quote — typically within 4 hours.
      </p>
    </div>
  </section>

  <!-- Form + Info -->
  <section class="py-16 md:py-24 bg-cream">
    <div class="max-w-[1400px] mx-auto px-5 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">
        <!-- Form -->
        <div class="lg:col-span-3" data-reveal>
          <form
            action="/api/contact"
            method="POST"
            class="space-y-6"
          >
            <!-- Native Honeypot -->
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-sm font-medium text-navy mb-2">Full Name</label>
                <input
                  type="text"
                  name="name"
                  id="name"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-navy/10 bg-white text-offblack
                         placeholder:text-offblack/30 focus:outline-none focus:ring-2 focus:ring-copper/30
                         focus:border-copper transition-all duration-200"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-navy mb-2">Email</label>
                <input
                  type="email"
                  name="email"
                  id="email"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-navy/10 bg-white text-offblack
                         placeholder:text-offblack/30 focus:outline-none focus:ring-2 focus:ring-copper/30
                         focus:border-copper transition-all duration-200"
                  placeholder="you@company.com"
                />
              </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <label for="phone" class="block text-sm font-medium text-navy mb-2">Phone</label>
                <input
                  type="tel"
                  name="phone"
                  id="phone"
                  class="w-full px-4 py-3 rounded-lg border border-navy/10 bg-white text-offblack
                         placeholder:text-offblack/30 focus:outline-none focus:ring-2 focus:ring-copper/30
                         focus:border-copper transition-all duration-200"
                  placeholder="+91 XXXXX XXXXX"
                />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-navy mb-2">Service Needed</label>
                <select
                  name="service"
                  id="service"
                  class="w-full px-4 py-3 rounded-lg border border-navy/10 bg-white text-offblack
                         focus:outline-none focus:ring-2 focus:ring-copper/30 focus:border-copper
                         transition-all duration-200 appearance-none"
                  style="background-image: url('data:image/svg+xml;charset=utf-8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2216%22 height=%2216%22 fill=%22none%22 stroke=%22%230C1E35%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22><path d=%22M4 6l4 4 4-4%22/></svg>'); background-repeat: no-repeat; background-position: right 1rem center; background-size: 1rem;"
                >
                  <option value="">Select a service</option>
                  <option value="customs">Customs Clearance</option>
                  <option value="ocean">Ocean Freight</option>
                  <option value="air">Air Freight</option>
                  <option value="road">Road Transport</option>
                  <option value="express">Express Delivery</option>
                  <option value="warehouse">Warehousing</option>
                  <option value="certificates">Certificates</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-navy mb-2">Message</label>
              <textarea
                name="message"
                id="message"
                rows="5"
                class="w-full px-4 py-3 rounded-lg border border-navy/10 bg-white text-offblack
                       placeholder:text-offblack/30 focus:outline-none focus:ring-2 focus:ring-copper/30
                       focus:border-copper transition-all duration-200 resize-vertical"
                placeholder="Tell us about your shipment — origin, destination, cargo type, volume..."
              ></textarea>
            </div>

            <button
              type="submit"
              class="inline-flex items-center gap-2 bg-copper text-white font-medium
                     px-8 py-3.5 rounded-lg hover:bg-copper-600 active:scale-[0.97]
                     transition-all duration-200 shadow-lg shadow-copper/20"
            >
              Send Request
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div class="lg:col-span-2" data-reveal style="--reveal-d:0.15s">
          <div class="rounded-2xl bg-navy p-8 md:p-10 text-white">
            <h3 class="font-display font-bold text-xl mb-8">Contact Information</h3>

            <div class="space-y-6">
              <!-- Phone -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-white/6 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-copper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" />
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Phone</p>
                  <a href="tel:+918439312613" class="text-sm font-medium hover:text-copper transition-colors">+91 84393 12613</a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-white/6 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-copper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="4" width="20" height="16" rx="2" />
                    <path d="M22 7l-10 7L2 7" />
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Email</p>
                  <a href="mailto:info@vishallogistics.in" class="text-sm font-medium hover:text-copper transition-colors">info@vishallogistics.in</a>
                </div>
              </div>

              <!-- WhatsApp -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-white/6 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-[#25D366]" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                    <path d="M12 2C6.477 2 2 6.477 2 12c0 1.89.525 3.66 1.438 5.168L2 22l4.832-1.438A9.955 9.955 0 0012 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18a8 8 0 01-4.243-1.214l-.258-.156-2.828.84.84-2.828-.156-.258A7.963 7.963 0 014 12a8 8 0 1116 0 8 8 0 01-8 8z"/>
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs uppercase tracking-wider mb-1">WhatsApp</p>
                  <a href="https://wa.me/918439312613" target="_blank" rel="noopener noreferrer" class="text-sm font-medium hover:text-copper transition-colors">Chat with us</a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex gap-4">
                <div class="w-10 h-10 rounded-lg bg-white/6 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-copper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
                    <circle cx="12" cy="10" r="3" />
                  </svg>
                </div>
                <div>
                  <p class="text-white/40 text-xs uppercase tracking-wider mb-1">Office</p>
                  <p class="text-sm leading-relaxed text-white/70">
                    15/18/592 Alakhnanda Colony,<br />Khushalpur, Uttar Pradesh, India
                  </p>
                </div>
              </div>
            </div>

            <!-- Divider -->
            <div class="my-8 h-px bg-white/8"></div>

            <div>
              <p class="text-white/40 text-xs uppercase tracking-wider mb-2">Business Hours</p>
              <p class="text-sm text-white/70">Monday — Saturday: 9:00 AM — 7:00 PM IST</p>
              <p class="text-sm text-white/40 mt-1">Sunday: Closed</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    const params = new URLSearchParams(window.location.search);
    if (!params.has('sent')) return;

    const form = document.querySelector('form');
    if (!form) return;

    const msg = document.createElement('div');
    msg.setAttribute('role', 'alert');
    msg.className =
      'rounded-lg bg-green-50 border border-green-200 text-green-800 p-4 text-sm font-medium mb-6';
    msg.textContent =
      'Your request has been sent successfully. We will get back to you shortly.';
    form.parentElement?.insertBefore(msg, form);
    form.reset();

    window.history.replaceState({}, '', window.location.pathname);
  });
</script>