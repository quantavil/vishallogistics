---
// src/pages/services.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const services = [
  {
    id: 'customs',
    title: 'Customs Clearance',
    desc: 'We manage the full documentation lifecycle for your imports and exports — from initial filing through final clearance. Our team handles duty and tax calculations, HSN classification, regulatory compliance, and all ICEGATE procedures so your goods move without bureaucratic friction.',
    features: [
      'Import/Export Documentation',
      'Duty & Tax Calculation',
      'Regulatory Compliance',
      'HSN Classification',
      'Consultancy Services',
      'ICEGATE Registration',
      'Ad Code Registration',
      'IFSC Code Registration (Sea/Air/ICD)',
      'RODTEP Scrip Generation',
    ],
    image: '/images/services/customs.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="12" y="8" width="30" height="42" rx="3"/><path d="M20 20h14M20 28h14M20 36h8"/><path d="M46 24l8 8-8 8" stroke-width="2"/></svg>`,
  },
  {
    id: 'ocean',
    title: 'Ocean Freight',
    desc: 'Competitive container shipping with multi-port coverage across major global trade lanes. We handle FCL and LCL bookings, reefer container coordination, and provide real-time container tracking through the LDB portal.',
    features: [
      'Best Ocean Freight Rates',
      'FCL & LCL Shipments',
      'Multi-Port Coverage',
      'Real-Time Container Tracking',
      'Reefer Container Handling',
    ],
    image: '/images/services/ocean.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M8 40c4-4 8-4 12 0s8 4 12 0 8-4 12 0 8 4 12 0"/><path d="M16 40V22l16-8 16 8v18"/><rect x="26" y="28" width="12" height="12" rx="1.5"/></svg>`,
  },
  {
    id: 'air',
    title: 'Air Freight',
    desc: 'For time-sensitive shipments, our air freight service delivers speed without compromising on care. We coordinate express and standard options, charter services for oversized cargo, and handle dangerous goods with full regulatory clearance.',
    features: [
      'Express & Standard Options',
      'Charter Services',
      'Dangerous Goods Handling',
      'Airport-to-Door Delivery',
    ],
    image: '/images/services/air.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M6 38l24-10 6-20 6 20 24 10-24 6-6 14-6-14z"/></svg>`,
  },
  {
    id: 'road',
    title: 'Road Transport',
    desc: 'Seamless inland haulage connecting your factory or warehouse to the nearest seaport, airport, or ICD. We coordinate full and part truckloads for import pick-ups and export dispatches — GPS-tracked end to end.',
    features: [
      'Factory to Port / ICD Haulage',
      'Port to Warehouse Delivery',
      'Full & Part Truckload',
      'GPS-Tracked Fleet',
    ],
    image: '/images/services/road.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><rect x="6" y="20" width="36" height="22" rx="3"/><path d="M42 28h10l6 10v4H42V28z"/><circle cx="18" cy="48" r="5"/><circle cx="50" cy="48" r="5"/></svg>`,
  },
  {
    id: 'express',
    title: 'Express Delivery',
    desc: 'When deadlines are non-negotiable, our express service guarantees transit times with priority handling. Same-day options are available for domestic shipments, with digital proof of delivery on every consignment.',
    features: [
      'Guaranteed Transit Times',
      'Priority Handling',
      'Same-Day Options',
      'Digital Proof of Delivery',
    ],
    image: '/images/services/express.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><circle cx="32" cy="32" r="24"/><path d="M32 16v16l10 10" stroke-width="2"/></svg>`,
  },
  {
    id: 'warehouse',
    title: 'Warehousing & Storage',
    desc: 'Strategic storage facilities equipped with climate-controlled units, round-the-clock CCTV security, and advanced inventory management systems. Pick-and-pack services available for distribution-ready shipments.',
    features: [
      'Climate-Controlled Units',
      '24/7 Security & CCTV',
      'Inventory Management Systems',
      'Pick & Pack Services',
    ],
    image: '/images/services/warehouse.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M8 28L32 12l24 16v26H8z"/><rect x="24" y="36" width="16" height="18" rx="1"/></svg>`,
  },
  {
    id: 'certificates',
    title: 'Certificates & Documentation',
    desc: 'We procure and process essential trade certificates that international shipments require — Certificate of Origin, Phytosanitary certificates, and Fumigation certificates — ensuring your cargo clears destination customs without complications.',
    features: [
      'Certificate of Origin',
      'Phytosanitary Certificates',
      'Fumigation Certificates',
      'Trade Compliance Documentation',
    ],
    image: '/images/services/certificates.png',
    icon: `<svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-full h-full"><path d="M38 6H16a5 5 0 00-5 5v42a5 5 0 005 5h32a5 5 0 005-5V21L38 6z"/><path d="M38 6v15h15"/><circle cx="32" cy="38" r="8"/><path d="M26 46l-3 12 9-4 9 4-3-12"/></svg>`,
  },
];
---

<Layout title="Our Services — Vishal Logistics Solutions">
  <!-- Hero -->
  <section class="bg-navy pt-32 pb-16 md:pt-36 md:pb-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 60px 60px;"></div>
    <div class="relative max-w-[1400px] mx-auto px-5 lg:px-8">
      <p class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-4" data-reveal>Services</p>
      <h1
        class="font-display font-extrabold text-white text-4xl md:text-5xl lg:text-6xl tracking-tight leading-[0.95]"
        data-reveal
        style="--reveal-d:0.1s"
      >
        Everything between your<br class="hidden md:block" /> dock and theirs.
      </h1>
      <p class="mt-5 text-white/40 text-lg max-w-[55ch]" data-reveal style="--reveal-d:0.2s">
        Seven core capabilities, one logistics partner. Each service is designed to eliminate delays, reduce costs, and give you full control of your supply chain.
      </p>
    </div>
  </section>

  <!-- Services detail -->
  {
    services.map((s, i) => (
      <section
        id={s.id}
        class:list={['py-16 md:py-24 scroll-mt-24', i % 2 === 0 ? 'bg-cream' : 'bg-white']}
      >
        <div class="max-w-[1400px] mx-auto px-5 lg:px-8">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
            <!-- Text -->
            <div class={i % 2 !== 0 ? 'lg:order-2' : ''} data-reveal>
              <div class="flex items-center gap-3 mb-5">
                <span class="text-xs font-mono text-copper/50 font-medium">0{i + 1}</span>
                <div class="h-px w-8 bg-copper/20" />
              </div>
              <h2 class="font-display font-bold text-navy text-2xl md:text-3xl lg:text-4xl tracking-tight">
                {s.title}
              </h2>
              <p class="mt-4 text-offblack/55 leading-relaxed max-w-[55ch]">{s.desc}</p>

              <ul class="mt-8 space-y-3">
                {s.features.map((f: string) => (
                  <li class="flex items-start gap-3 text-sm text-offblack/60">
                    <svg class="w-4 h-4 text-copper shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M5 12l5 5L20 7" />
                    </svg>
                    {f}
                  </li>
                ))}
              </ul>


              <a
                href={`/contact?service=${s.id}`}
                class="mt-8 inline-flex items-center gap-2 bg-navy text-white text-sm font-medium
                       px-6 py-3 rounded-lg hover:bg-navy-800 active:scale-[0.97] transition-all duration-200"
              >
                Get {s.title} Quote
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7" />
                </svg>
              </a>
            </div>

            <!-- Visual -->
            <div
              class={i % 2 !== 0 ? 'lg:order-1' : ''}
              data-reveal={i % 2 !== 0 ? 'left' : 'right'}
              style="--reveal-d:0.15s"
            >
              <div class="relative rounded-2xl overflow-hidden shadow-xl aspect-4/3 group">
                <img
                  src={s.image}
                  alt={s.title}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading={i < 2 ? "eager" : "lazy"}
                />
              </div>
            </div>
          </div>
        </div>
      </section>
    ))
  }

  <CTA />
</Layout>