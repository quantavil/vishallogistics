---
// src/pages/404.astro
export const prerender = true;

import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found — Vishal Logistics Solutions">
  <section class="bg-cream min-h-[80dvh] flex items-center justify-center">
    <div class="max-w-[1400px] mx-auto px-5 lg:px-8 text-center py-24">
      <p
        class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-6"
        data-reveal
      >
        Error 404
      </p>

      <h1
        class="font-display font-extrabold text-navy text-5xl md:text-6xl lg:text-7xl tracking-tight leading-[1.0]"
        data-reveal
        style="--reveal-d:0.1s"
      >
        Page not found
      </h1>

      <p
        class="mt-6 text-offblack/50 text-lg max-w-[45ch] mx-auto"
        data-reveal
        style="--reveal-d:0.2s"
      >
        The page you are looking for does not exist or has been moved. Let us
        get you back on track.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-4" data-reveal style="--reveal-d:0.3s">
        <a
          href="/"
          class="inline-flex items-center gap-2 bg-copper text-white font-medium
                 px-7 py-3.5 rounded-lg hover:bg-copper-600 active:scale-[0.97]
                 transition-all duration-200 shadow-lg shadow-copper/20"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"></path>
          </svg>
          Back to Home
        </a>
        <a
          href="/services"
          class="inline-flex items-center gap-2 border border-navy/15 text-navy font-medium
                 px-7 py-3.5 rounded-lg hover:bg-navy hover:text-white hover:border-navy
                 active:scale-[0.97] transition-all duration-200"
        >
          View Services
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-copper font-medium
                 px-4 py-3.5 hover:underline underline-offset-4 transition-all duration-200"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</Layout>
