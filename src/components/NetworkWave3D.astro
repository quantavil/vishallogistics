---
// src/components/NetworkWave3D.astro
---

<canvas
  id="hero-3d-canvas"
  class="absolute inset-0 w-full h-full z-0 pointer-events-auto cursor-grab active:cursor-grabbing"
></canvas>

<script>
  import * as THREE from 'three';

  function initHero3D() {
    const canvas = document.getElementById('hero-3d-canvas') as HTMLCanvasElement | null;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    const container = canvas.parentElement;
    if (!container) return;

    // ─── Configuration (all magic numbers extracted) ──────────────────
    const CONFIG = {
      bg:           0xfdfbf7,
      fogDensity:   0.03,
      wireColor:    0x0c1e35,
      wireOpacity:  0.12,
      accentColor:  0xd4622b,
      dotSize:      0.3,
      dotOpacity:   0.75,
      cameraZ:      22,
      fov:          60,
      plane:        { w: 60, h: 40, segX: 48, segY: 32 },
      wave:         { speed: 0.4 },
      ripple:       { speed: 10, lifetime: 4, maxAmp: 3.5, ampScale: 2.5 },
      hover:        { radius: 6, strength: 1.5 },
      parallax:     { x: 0.8, y: 0.4, lerp: 2 },
      groupOffset:  { x: 8, rotX: -Math.PI * 0.1, rotY: -Math.PI * 0.1 },
    } as const;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const motionScale   = reducedMotion ? 0.15 : 1;

    // ─── Scene ────────────────────────────────────────────────────────
    const scene  = new THREE.Scene();
    scene.fog    = new THREE.FogExp2(CONFIG.bg, CONFIG.fogDensity);

    const camera = new THREE.PerspectiveCamera(
      CONFIG.fov,
      container.clientWidth / container.clientHeight,
      0.1,
      100,
    );
    camera.position.set(0, 0, CONFIG.cameraZ);

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.setSize(container.clientWidth, container.clientHeight);

    // ─── Geometry + original-position snapshot ────────────────────────
    const geometry  = new THREE.PlaneGeometry(
      CONFIG.plane.w, CONFIG.plane.h,
      CONFIG.plane.segX, CONFIG.plane.segY,
    );
    // One-liner copy instead of manual loop
    const originals = new Float32Array(geometry.attributes.position.array as Float32Array);
    geometry.setAttribute('aOriginalPosition', new THREE.BufferAttribute(originals, 3));

    // ─── Soft-circle dot texture (replaces hard squares) ──────────────
    const dotTexture = (() => {
      const size = 64;
      const c    = document.createElement('canvas');
      c.width = c.height = size;
      const ctx  = c.getContext('2d')!;
      const half = size / 2;
      const g    = ctx.createRadialGradient(half, half, 0, half, half, half);
      g.addColorStop(0,    'rgba(255,255,255,1)');
      g.addColorStop(0.25, 'rgba(255,255,255,0.92)');
      g.addColorStop(0.55, 'rgba(255,255,255,0.35)');
      g.addColorStop(1,    'rgba(255,255,255,0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, size, size);
      return new THREE.CanvasTexture(c);
    })();

    // ─── Materials ────────────────────────────────────────────────────
    const wireMaterial = new THREE.MeshBasicMaterial({
      color:       CONFIG.wireColor,
      wireframe:   true,
      transparent: true,
      opacity:     CONFIG.wireOpacity,
    });

    const pointsMaterial = new THREE.PointsMaterial({
      color:           CONFIG.accentColor,
      size:            CONFIG.dotSize,
      map:             dotTexture,
      sizeAttenuation: true,
      transparent:     true,
      opacity:         CONFIG.dotOpacity,
      depthWrite:      false,              // correct blending for transparency
    });

    // ─── Scene graph ──────────────────────────────────────────────────
    const waveGroup = new THREE.Group();
    waveGroup.position.x  = CONFIG.groupOffset.x;
    waveGroup.rotation.x  = CONFIG.groupOffset.rotX;
    waveGroup.rotation.y  = CONFIG.groupOffset.rotY;
    waveGroup.add(
      new THREE.Mesh(geometry, wireMaterial),
      new THREE.Points(geometry, pointsMaterial),
    );
    scene.add(waveGroup);

    // Invisible hit-plane aligned with wave for raycasting
    const hitMaterial = new THREE.MeshBasicMaterial({ visible: false });
    const hitMesh     = new THREE.Mesh(new THREE.PlaneGeometry(100, 100), hitMaterial);
    hitMesh.position.copy(waveGroup.position);
    hitMesh.rotation.copy(waveGroup.rotation);
    scene.add(hitMesh);

    // ─── Interaction state ────────────────────────────────────────────
    const raycaster  = new THREE.Raycaster();
    const ndcVec     = new THREE.Vector2();          // reused every frame
    const camTarget  = new THREE.Vector2();
    const camCurrent = new THREE.Vector2();
    const hoverPoint = new THREE.Vector3();
    let   hasHover   = false;

    interface Ripple { origin: THREE.Vector3; startTime: number }
    const ripples: Ripple[] = [];
    let time      = 0;
    let isVisible = true;
    let frameId   = 0;

    // ─── Shared helpers ───────────────────────────────────────────────
    /** Convert a pointer event to normalised-device-coordinates (reuses vec) */
    function toNDC(e: PointerEvent): THREE.Vector2 {
      const r = container!.getBoundingClientRect();
      return ndcVec.set(
        ((e.clientX - r.left) / r.width)  *  2 - 1,
        -((e.clientY - r.top) / r.height) *  2 + 1,
      );
    }

    /** Raycast NDC → wave-local hit point.  Returns null on miss. */
    function raycastLocal(ndc: THREE.Vector2, out: THREE.Vector3): boolean {
      raycaster.setFromCamera(ndc, camera);
      const hits = raycaster.intersectObject(hitMesh);
      if (!hits.length) return false;
      out.copy(hits[0].point);
      waveGroup.worldToLocal(out);
      return true;
    }

    // ─── Event handlers ───────────────────────────────────────────────
    function onPointerDown(e: PointerEvent) {
      const tmp = new THREE.Vector3();               // allocate only on click (rare)
      if (raycastLocal(toNDC(e), tmp)) {
        ripples.push({ origin: tmp, startTime: time });
      }
    }

    function onPointerMove(e: PointerEvent) {
      const ndc = toNDC(e);
      camTarget.set(ndc.x * CONFIG.parallax.x, ndc.y * CONFIG.parallax.y);
      hasHover = raycastLocal(ndc, hoverPoint);      // reuses shared vec3
    }

    function onPointerLeave() {
      camTarget.set(0, 0);
      hasHover = false;
    }

    container.addEventListener('pointerdown',   onPointerDown);
    container.addEventListener('pointermove',    onPointerMove);
    container.addEventListener('pointerleave',   onPointerLeave);

    // ─── Observers ────────────────────────────────────────────────────
    const resizeObs = new ResizeObserver(() => {
      camera.aspect = container.clientWidth / container.clientHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(container.clientWidth, container.clientHeight);
    });
    resizeObs.observe(container);

    const visObs = new IntersectionObserver(
      ([entry]) => { isVisible = entry.isIntersecting; },
    );
    visObs.observe(canvas);

    // ─── Render loop ──────────────────────────────────────────────────
    const clock = new THREE.Clock();

    function animate() {
      frameId = requestAnimationFrame(animate);
      if (!isVisible) return;

      const dt = clock.getDelta();
      time += dt * CONFIG.wave.speed * motionScale;

      // Expire dead ripples (reverse-iterate for safe splice)
      for (let i = ripples.length - 1; i >= 0; i--) {
        if (time - ripples[i].startTime > CONFIG.ripple.lifetime) {
          ripples.splice(i, 1);
        }
      }

      // Smooth camera parallax
      camCurrent.lerp(camTarget, dt * CONFIG.parallax.lerp);
      camera.position.x = camCurrent.x;
      camera.position.y = camCurrent.y;
      camera.lookAt(0, 0, 0);

      // ── Per-vertex wave update ──────────────────────────────────────
      const pos  = geometry.attributes.position;
      const orig = geometry.attributes.aOriginalPosition;
      const rLen = ripples.length;

      for (let i = 0; i < pos.count; i++) {
        const ox = orig.getX(i);
        const oy = orig.getY(i);

        // Base undulation
        let z =
          Math.sin(ox * 0.2  + time * 1.2) * 0.8 +
          Math.cos(oy * 0.25 - time * 0.9) * 0.6;

        // Hover bump — smooth quadratic falloff under cursor
        if (hasHover) {
          const dx = ox - hoverPoint.x;
          const dy = oy - hoverPoint.y;
          const t  = Math.max(0, 1 - Math.sqrt(dx * dx + dy * dy) / CONFIG.hover.radius);
          z += t * t * CONFIG.hover.strength;
        }

        // Click-ripple contributions (skipped entirely when empty)
        if (rLen > 0) {
          let rz = 0;
          for (let j = 0; j < rLen; j++) {
            const r    = ripples[j];
            const dx   = ox - r.origin.x;
            const dy   = oy - r.origin.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const age  = time - r.startTime;
            const front = age * CONFIG.ripple.speed;

            const damping =
              (1 / (1 + dist * 0.2)) *                             // spatial falloff
              Math.min(1, age * 3.33) *                            // soft intro
              Math.max(0, 1 - age / CONFIG.ripple.lifetime) *      // fade out
              Math.max(0, 1 - Math.max(0, dist - front) * 0.5);   // wavefront edge

            if (damping > 0.001) {
              rz += Math.cos(dist * 0.8 - age * 6) * CONFIG.ripple.ampScale * damping;
            }
          }
          z += Math.max(-CONFIG.ripple.maxAmp, Math.min(CONFIG.ripple.maxAmp, rz));
        }

        pos.setZ(i, z);
      }

      pos.needsUpdate = true;
      // ❌ REMOVED: computeVertexNormals() — MeshBasicMaterial ignores normals
      renderer.render(scene, camera);
    }

    animate();

    // ─── Cleanup on Astro page swap (prevents memory leak) ────────────
    function dispose() {
      cancelAnimationFrame(frameId);

      container!.removeEventListener('pointerdown',  onPointerDown);
      container!.removeEventListener('pointermove',   onPointerMove);
      container!.removeEventListener('pointerleave',  onPointerLeave);
      resizeObs.disconnect();
      visObs.disconnect();

      geometry.dispose();
      wireMaterial.dispose();
      pointsMaterial.dispose();
      dotTexture.dispose();
      hitMesh.geometry.dispose();
      hitMaterial.dispose();
      renderer.dispose();

      delete canvas!.dataset.initialized;
    }

    document.addEventListener('astro:before-swap', dispose, { once: true });
  }

  // Both hooks ensure init on first load AND Astro client-side navigations
  document.addEventListener('astro:page-load', initHero3D);
  initHero3D();
</script>