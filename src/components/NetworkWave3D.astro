---
// src/components/NetworkWave3D.astro
---

<canvas
  id="hero-3d-canvas"
  class="absolute inset-0 w-full h-full z-0 pointer-events-auto cursor-grab active:cursor-grabbing"
></canvas>

<script>
  function initHero3D() {
    const canvas = document.getElementById('hero-3d-canvas') as HTMLCanvasElement;
    if (!canvas || canvas.dataset.initialized) return;
    canvas.dataset.initialized = 'true';

    const container = canvas.parentElement as HTMLElement;
    if (!container) return;

    const ctx = canvas.getContext('2d') as CanvasRenderingContext2D;
    if (!ctx) return;

    const CONFIG = {
      fogDensity: 0.03,
      wireColor: 0x0c1e35,
      wireOpacity: 0.12,
      accentColor: 0xd4622b,
      dotSize: 0.3,
      dotOpacity: 0.75,
      cameraZ: 22,
      fov: 60,
      plane: { w: 60, h: 40, segX: 48, segY: 32 },
      wave: { speed: 0.4 },
      ripple: { speed: 10, lifetime: 4, maxAmp: 3.5, ampScale: 2.5 },
      hover: { radius: 6, strength: 1.5 },
      parallax: { x: 0.8, y: 0.4, lerp: 2 },
      groupOffset: { x: 8, rotX: -Math.PI * 0.1, rotY: -Math.PI * 0.1 },
      hitPlaneHalf: 50,
    };

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const motionScale = reducedMotion ? 0.15 : 1;

    const gridX = CONFIG.plane.segX + 1;
    const gridY = CONFIG.plane.segY + 1;
    const count = gridX * gridY;

    const originals = new Float32Array(count * 3);
    const screen = new Float32Array(count * 3);

    const rotX = CONFIG.groupOffset.rotX;
    const rotY = CONFIG.groupOffset.rotY;
    const cx = Math.cos(rotX);
    const sx = Math.sin(rotX);
    const cy = Math.cos(rotY);
    const sy = Math.sin(rotY);

    const planePoint = { x: CONFIG.groupOffset.x, y: 0, z: 0 };
    const planeNormal = {
      x: cx * sy,
      y: -sx,
      z: cx * cy,
    };

    const tanHalfFov = Math.tan((CONFIG.fov * Math.PI) / 180 / 2);

    let width = 1;
    let height = 1;
    let dpr = 1;
    let aspect = 1;
    let focalPx = 1;

    const camera = { x: 0, y: 0, z: CONFIG.cameraZ };
    const camTarget = { x: 0, y: 0 };
    const camCurrent = { x: 0, y: 0 };

    const basis = {
      forward: { x: 0, y: 0, z: -1 },
      right: { x: 1, y: 0, z: 0 },
      up: { x: 0, y: 1, z: 0 },
    };

    const hoverPoint = { x: 0, y: 0, z: 0 };
    const tmpHit = { x: 0, y: 0, z: 0 };
    let hasHover = false;

    const ripples: { x: number; y: number; startTime: number }[] = [];
    let time = 0;
    let frameId = 0;
    let isVisible = true;
    let lastNow = performance.now();

    function hexToRgb(hex: number) {
      return [(hex >> 16) & 255, (hex >> 8) & 255, hex & 255];
    }

    function rgbCss(hex: number) {
      const [r, g, b] = hexToRgb(hex);
      return `rgb(${r}, ${g}, ${b})`;
    }

    const wireCss = rgbCss(CONFIG.wireColor);
    const [accentR, accentG, accentB] = hexToRgb(CONFIG.accentColor);

    const dotSprite = (() => {
      const size = 64;
      const c = document.createElement('canvas');
      c.width = c.height = size;
      const sctx = c.getContext('2d') as CanvasRenderingContext2D;
      const half = size / 2;
      const g = sctx.createRadialGradient(half, half, 0, half, half, half);

      g.addColorStop(0, `rgba(${accentR},${accentG},${accentB},1)`);
      g.addColorStop(0.25, `rgba(${accentR},${accentG},${accentB},0.92)`);
      g.addColorStop(0.55, `rgba(${accentR},${accentG},${accentB},0.35)`);
      g.addColorStop(1, `rgba(${accentR},${accentG},${accentB},0)`);

      sctx.fillStyle = g;
      sctx.fillRect(0, 0, size, size);
      return c;
    })();

    function resize() {
      width = Math.max(1, container.clientWidth);
      height = Math.max(1, container.clientHeight);
      aspect = width / height;
      focalPx = height / (2 * tanHalfFov);

      dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = Math.round(width * dpr);
      canvas.height = Math.round(height * dpr);
      canvas.style.width = width + 'px';
      canvas.style.height = height + 'px';

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.imageSmoothingEnabled = true;
    }

    function updateCameraBasis() {
      camera.x = camCurrent.x;
      camera.y = camCurrent.y;
      camera.z = CONFIG.cameraZ;

      let fx = -camera.x;
      let fy = -camera.y;
      let fz = -camera.z;

      const fl = Math.hypot(fx, fy, fz) || 1;
      fx /= fl;
      fy /= fl;
      fz /= fl;

      let rx = -fz;
      let ry = 0;
      let rz = fx;

      const rl = Math.hypot(rx, ry, rz) || 1;
      rx /= rl;
      ry /= rl;
      rz /= rl;

      const ux = ry * fz - rz * fy;
      const uy = rz * fx - rx * fz;
      const uz = rx * fy - ry * fx;

      basis.forward.x = fx;
      basis.forward.y = fy;
      basis.forward.z = fz;

      basis.right.x = rx;
      basis.right.y = ry;
      basis.right.z = rz;

      basis.up.x = ux;
      basis.up.y = uy;
      basis.up.z = uz;
    }

    function fogFade(depth: number) {
      return Math.exp(-Math.pow(CONFIG.fogDensity * depth, 2));
    }

    function toNDC(e: PointerEvent) {
      const r = container.getBoundingClientRect();
      return {
        x: ((e.clientX - r.left) / r.width) * 2 - 1,
        y: -((e.clientY - r.top) / r.height) * 2 + 1,
      };
    }

    function raycastLocal(ndcX: number, ndcY: number, out: { x: number; y: number; z: number }) {
      const dirCamX = ndcX * aspect * tanHalfFov;
      const dirCamY = ndcY * tanHalfFov;
      const dirCamZ = 1;

      let dx =
        basis.right.x * dirCamX +
        basis.up.x * dirCamY +
        basis.forward.x * dirCamZ;
      let dy =
        basis.right.y * dirCamX +
        basis.up.y * dirCamY +
        basis.forward.y * dirCamZ;
      let dz =
        basis.right.z * dirCamX +
        basis.up.z * dirCamY +
        basis.forward.z * dirCamZ;

      const dl = Math.hypot(dx, dy, dz) || 1;
      dx /= dl;
      dy /= dl;
      dz /= dl;

      const denom =
        dx * planeNormal.x +
        dy * planeNormal.y +
        dz * planeNormal.z;

      if (Math.abs(denom) < 1e-6) return false;

      const t =
        ((planePoint.x - camera.x) * planeNormal.x +
          (planePoint.y - camera.y) * planeNormal.y +
          (planePoint.z - camera.z) * planeNormal.z) /
        denom;

      if (t <= 0) return false;

      const wx = camera.x + dx * t;
      const wy = camera.y + dy * t;
      const wz = camera.z + dz * t;

      const x0 = wx - CONFIG.groupOffset.x;
      const y0 = wy;
      const z0 = wz;

      const ix = x0 * cy - z0 * sy;
      const iz = x0 * sy + z0 * cy;

      out.x = ix;
      out.y = y0 * cx + iz * sx;
      out.z = -y0 * sx + iz * cx;

      return (
        Math.abs(out.x) <= CONFIG.hitPlaneHalf &&
        Math.abs(out.y) <= CONFIG.hitPlaneHalf
      );
    }

    function projectWorldToScreen(wx: number, wy: number, wz: number, outIndex: number) {
      const relX = wx - camera.x;
      const relY = wy - camera.y;
      const relZ = wz - camera.z;

      const xCam =
        relX * basis.right.x +
        relY * basis.right.y +
        relZ * basis.right.z;

      const yCam =
        relX * basis.up.x +
        relY * basis.up.y +
        relZ * basis.up.z;

      const zCam =
        relX * basis.forward.x +
        relY * basis.forward.y +
        relZ * basis.forward.z;

      const i = outIndex * 3;

      if (zCam <= 0.01) {
        screen[i] = 0;
        screen[i + 1] = 0;
        screen[i + 2] = -1;
        return;
      }

      const ndcX = xCam / (zCam * tanHalfFov * aspect);
      const ndcY = yCam / (zCam * tanHalfFov);

      screen[i] = (ndcX * 0.5 + 0.5) * width;
      screen[i + 1] = (-ndcY * 0.5 + 0.5) * height;
      screen[i + 2] = zCam;
    }

    function drawWire() {
      ctx.strokeStyle = wireCss;
      ctx.globalAlpha = CONFIG.wireOpacity;
      ctx.lineWidth = 1;
      ctx.lineCap = 'round';
      ctx.lineJoin = 'round';

      ctx.beginPath();

      for (let y = 0; y < gridY; y++) {
        for (let x = 0; x < gridX; x++) {
          const i = y * gridX + x;
          const a = i * 3;

          if (screen[a + 2] <= 0) continue;

          if (x < gridX - 1) {
            const j = i + 1;
            const b = j * 3;
            if (screen[b + 2] > 0) {
              ctx.moveTo(screen[a], screen[a + 1]);
              ctx.lineTo(screen[b], screen[b + 1]);
            }
          }

          if (y < gridY - 1) {
            const j = i + gridX;
            const b = j * 3;
            if (screen[b + 2] > 0) {
              ctx.moveTo(screen[a], screen[a + 1]);
              ctx.lineTo(screen[b], screen[b + 1]);
            }
          }
        }
      }

      ctx.stroke();
    }

    function drawPoints() {
      for (let i = 0; i < count; i++) {
        const s = i * 3;
        const depth = screen[s + 2];
        if (depth <= 0) continue;

        const px = screen[s];
        const py = screen[s + 1];
        const size = Math.max(2, (CONFIG.dotSize * focalPx) / depth);

        if (
          px < -size || px > width + size ||
          py < -size || py > height + size
        ) continue;

        const alpha = CONFIG.dotOpacity * fogFade(depth);
        if (alpha <= 0.01) continue;

        ctx.globalAlpha = alpha;
        ctx.drawImage(dotSprite, px - size / 2, py - size / 2, size, size);
      }
    }

    function render() {
      ctx.clearRect(0, 0, width, height);
      drawWire();
      drawPoints();
      ctx.globalAlpha = 1;
    }

    function onPointerDown(e: PointerEvent) {
      const ndc = toNDC(e);
      if (raycastLocal(ndc.x, ndc.y, tmpHit)) {
        ripples.push({
          x: tmpHit.x,
          y: tmpHit.y,
          startTime: time,
        });
      }
    }

    function onPointerMove(e: PointerEvent) {
      const ndc = toNDC(e);
      camTarget.x = ndc.x * CONFIG.parallax.x;
      camTarget.y = ndc.y * CONFIG.parallax.y;
      hasHover = raycastLocal(ndc.x, ndc.y, hoverPoint);
    }

    function onPointerLeave() {
      camTarget.x = 0;
      camTarget.y = 0;
      hasHover = false;
    }

    function animate(now: number) {
      frameId = requestAnimationFrame(animate);

      if (!isVisible) {
        lastNow = now;
        return;
      }

      const dt = Math.min(0.05, (now - lastNow) / 1000);
      lastNow = now;

      time += dt * CONFIG.wave.speed * motionScale;

      for (let i = ripples.length - 1; i >= 0; i--) {
        if (time - ripples[i].startTime > CONFIG.ripple.lifetime) {
          ripples.splice(i, 1);
        }
      }

      const lerp = Math.min(1, dt * CONFIG.parallax.lerp);
      camCurrent.x += (camTarget.x - camCurrent.x) * lerp;
      camCurrent.y += (camTarget.y - camCurrent.y) * lerp;

      updateCameraBasis();

      for (let i = 0; i < count; i++) {
        const p = i * 3;
        const ox = originals[p];
        const oy = originals[p + 1];

        let z =
          Math.sin(ox * 0.2 + time * 1.2) * 0.8 +
          Math.cos(oy * 0.25 - time * 0.9) * 0.6;

        if (hasHover) {
          const dx = ox - hoverPoint.x;
          const dy = oy - hoverPoint.y;
          const t = Math.max(
            0,
            1 - Math.sqrt(dx * dx + dy * dy) / CONFIG.hover.radius
          );
          z += t * t * CONFIG.hover.strength;
        }

        if (ripples.length > 0) {
          let rz = 0;

          for (let j = 0; j < ripples.length; j++) {
            const r = ripples[j];
            const dx = ox - r.x;
            const dy = oy - r.y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            const age = time - r.startTime;
            const front = age * CONFIG.ripple.speed;

            const damping =
              (1 / (1 + dist * 0.2)) *
              Math.min(1, age * 3.33) *
              Math.max(0, 1 - age / CONFIG.ripple.lifetime) *
              Math.max(0, 1 - Math.max(0, dist - front) * 0.5);

            if (damping > 0.001) {
              rz +=
                Math.cos(dist * 0.8 - age * 6) *
                CONFIG.ripple.ampScale *
                damping;
            }
          }

          z += Math.max(
            -CONFIG.ripple.maxAmp,
            Math.min(CONFIG.ripple.maxAmp, rz)
          );
        }

        const y1 = oy * cx - z * sx;
        const z1 = oy * sx + z * cx;
        const x1 = ox;

        const wx = x1 * cy + z1 * sy + CONFIG.groupOffset.x;
        const wy = y1;
        const wz = -x1 * sy + z1 * cy;

        projectWorldToScreen(wx, wy, wz, i);
      }

      render();
    }

    const stepX = CONFIG.plane.w / CONFIG.plane.segX;
    const stepY = CONFIG.plane.h / CONFIG.plane.segY;
    const startX = -CONFIG.plane.w / 2;
    const startY = -CONFIG.plane.h / 2;

    for (let y = 0; y < gridY; y++) {
      for (let x = 0; x < gridX; x++) {
        const i = (y * gridX + x) * 3;
        originals[i] = startX + x * stepX;
        originals[i + 1] = startY + y * stepY;
        originals[i + 2] = 0;
      }
    }

    resize();
    updateCameraBasis();

    container.addEventListener('pointerdown', onPointerDown);
    container.addEventListener('pointermove', onPointerMove);
    container.addEventListener('pointerleave', onPointerLeave);

    const resizeObs = new ResizeObserver(() => resize());
    resizeObs.observe(container);

    const visObs = new IntersectionObserver(([entry]) => {
      isVisible = entry.isIntersecting;
    });
    visObs.observe(canvas);

    frameId = requestAnimationFrame(animate);

    function dispose() {
      cancelAnimationFrame(frameId);
      container.removeEventListener('pointerdown', onPointerDown);
      container.removeEventListener('pointermove', onPointerMove);
      container.removeEventListener('pointerleave', onPointerLeave);
      resizeObs.disconnect();
      visObs.disconnect();
      delete canvas.dataset.initialized;
    }

    document.addEventListener('astro:before-swap', dispose, { once: true });
  }

  document.addEventListener('astro:page-load', initHero3D);
  initHero3D();
</script>