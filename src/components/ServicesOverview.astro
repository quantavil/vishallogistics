---
const services = [
  {
    title: 'Customs Clearance',
    desc: 'Import/export documentation, duty calculation, HSN classification, ICEGATE registration, and full regulatory compliance — handled start to finish.',
    href: '/services#customs',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><rect x="8" y="6" width="24" height="32" rx="2"/><path d="M14 14h12M14 20h12M14 26h8"/><path d="M36 18l6 6-6 6" stroke-width="2"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Ocean Freight',
    desc: 'FCL, LCL, reefer containers, and multi-port coverage with real-time tracking and competitive rates.',
    href: '/services#ocean',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M6 30c3-3 6-3 9 0s6 3 9 0 6-3 9 0 6 3 9 0"/><path d="M12 30V16l12-6 12 6v14"/><rect x="20" y="20" width="8" height="10" rx="1"/></svg>`,
    span: '',
  },
  {
    title: 'Air Freight',
    desc: 'Express and standard air cargo, charter services, and dangerous goods handling for time-critical shipments.',
    href: '/services#air',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M4 28l18-8 4-14 4 14 18 8-18 4-4 10-4-10z"/></svg>`,
    span: '',
  },
  {
    title: 'Road Transport',
    desc: 'Full and part truckload, last-mile delivery with GPS tracking across the entire Indian subcontinent.',
    href: '/services#road',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><rect x="4" y="14" width="28" height="18" rx="2"/><path d="M32 20h8l4 8v4h-12V20z"/><circle cx="14" cy="36" r="4"/><circle cx="38" cy="36" r="4"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Express Delivery',
    desc: 'Guaranteed transit times, same-day options, priority handling, and digital proof of delivery.',
    href: '/services#express',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><circle cx="24" cy="24" r="18"/><path d="M24 14v10l7 7" stroke-width="2"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Warehousing',
    desc: 'Climate-controlled units, 24/7 security with CCTV, inventory management, and pick-and-pack services.',
    href: '/services#warehouse',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M6 20L24 8l18 12v20H6z"/><rect x="18" y="28" width="12" height="12"/></svg>`,
    span: '',
  },
  {
    title: 'Certificates & Documentation',
    desc: 'Certificate of Origin, Phytosanitary certificates, Fumigation certificates, Ad Code and IFSC registration, RODTEP scrip generation.',
    href: '/services#certificates',
    icon: `<svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M28 4H12a4 4 0 00-4 4v32a4 4 0 004 4h24a4 4 0 004-4V16L28 4z"/><path d="M28 4v12h12"/><circle cx="24" cy="30" r="6"/><path d="M20 36l-2 8 6-3 6 3-2-8"/></svg>`,
    span: 'lg:col-span-3',
  },
];
---

<section class="py-20 md:py-28 bg-cream" id="services-overview">
  <div class="max-w-[1400px] mx-auto px-5 lg:px-8">
    <div class="max-w-2xl" data-reveal>
      <p class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-4">What We Do</p>
      <h2 class="font-display font-bold text-navy text-3xl md:text-4xl lg:text-5xl tracking-tight">
        Every link in your supply chain, covered.
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        services.map((s, i) => (
          <a
            href={s.href}
            class:list={[
              'group relative p-7 md:p-8 rounded-2xl border border-navy/[0.06] bg-white',
              'hover:border-copper/20 hover:shadow-xl hover:shadow-copper/[0.04]',
              'transition-all duration-300 active:scale-[0.98]',
              s.span,
            ]}
            data-reveal
            style={`--reveal-d:${i * 0.07}s`}
          >
            <div
              class="w-12 h-12 rounded-xl bg-navy/[0.04] flex items-center justify-center
                      text-navy group-hover:bg-copper group-hover:text-white transition-colors duration-300"
              set:html={s.icon}
            />
            <h3 class="mt-5 font-display font-bold text-navy text-lg">{s.title}</h3>
            <p class="mt-2 text-offblack/50 text-sm leading-relaxed">{s.desc}</p>
            <div
              class="mt-5 flex items-center gap-1.5 text-copper text-sm font-medium
                      transition-all duration-300
                      lg:opacity-0 lg:translate-x-[-8px] lg:group-hover:opacity-100 lg:group-hover:translate-x-0 lg:group-focus-visible:opacity-100"
            >
              Learn more
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>