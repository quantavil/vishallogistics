---

<section class="py-20 md:py-28 bg-cream" id="services-overview">
  <div class="max-w-[1400px] mx-auto px-5 lg:px-8">
    <div class="max-w-2xl" data-reveal>
      <p class="text-xs uppercase tracking-[0.25em] font-medium text-copper mb-4">What We Do</p>
      <h2 class="font-display font-bold text-navy text-3xl md:text-4xl lg:text-5xl tracking-tight">
        Every link in your supply chain, covered.
      </h2>
    </div>

    <div class="mt-14 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {
        services.map((s, i) => (
          <a
            href={s.href}
            class:list={[
              'group relative p-7 md:p-8 rounded-2xl border border-navy/[0.06] bg-white',
              'hover:border-copper/20 hover:shadow-xl hover:shadow-copper/[0.04]',
              'transition-all duration-300 active:scale-[0.98]',
              s.span,
            ]}
            data-reveal
            style={`--reveal-d:${i * 0.07}s`}
          >
            <div
              class="w-12 h-12 rounded-xl bg-navy/[0.04] flex items-center justify-center
                      text-navy group-hover:bg-copper group-hover:text-white transition-colors duration-300"
              set:html={s.icon}
            />
            <h3 class="mt-5 font-display font-bold text-navy text-lg">{s.title}</h3>
            <p class="mt-2 text-offblack/50 text-sm leading-relaxed">{s.desc}</p>
            <div
              class="mt-5 flex items-center gap-1.5 text-copper text-sm font-medium
                      transition-all duration-300
                      lg:opacity-0 lg:translate-x-[-8px] lg:group-hover:opacity-100 lg:group-hover:translate-x-0 lg:group-focus-visible:opacity-100"
            >
              Learn more
              <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>