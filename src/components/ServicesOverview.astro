  ---
const services = [
  {
    title: 'Customs Clearance',
    desc: 'Import/export documentation, duty calculation, HSN classification, ICEGATE registration, and full regulatory compliance — handled start to finish.',
    href: '/services#customs',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M9 14l2 2 4-4"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Ocean Freight',
    desc: 'FCL, LCL, reefer containers, and multi-port coverage with real-time tracking and competitive rates.',
    href: '/services#ocean',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M2 21c.6.5 1.2 1 2.5 1 2.5 0 2.5-2 5-2 2.6 0 2.4 2 5 2 2.5 0 2.5-2 5-2 1.3 0 1.9.5 2.5 1"/><path d="M19.38 20A11.6 11.6 0 0 0 21 14l-9-4-9 4c0 2.9.94 5.34 2.81 7.76"/><path d="M19 13V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v6"/></svg>`,
    span: '',
  },
  {
    title: 'Air Freight',
    desc: 'Express and standard air cargo, charter services, and dangerous goods handling for time-critical shipments.',
    href: '/services#air',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M17.8 19.2 16 11l3.5-3.5C21 6 21.5 4 21 3c-1-.5-3 0-4.5 1.5L13 8 4.8 6.2c-.5-.1-.9.2-1.1.6L2.5 9l8.1 3.5-3.1 3.1-4.2-.6c-.5 0-.9.2-1.1.7L1 17.5l4.6 1.4 1.4 4.6 1.8-1.2c.5-.2.7-.6.7-1.1l-.6-4.2 3.1-3.1 3.5 8.1c.4.9 1.1 1.2 1.6 1.1l2.2-1.3c.4-.2.7-.6.6-1.1z"/></svg>`,
    span: '',
  },
  {
    title: 'Road Transport',
    desc: 'Inland haulage connecting factories and warehouses to seaports, airports, and ICDs — coordinating import pick-ups and export dispatches with GPS-tracked trucks.',
    href: '/services#road',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"/><path d="M14 9h4l4 4v5c0 .6-.4 1-1 1h-2"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Express Delivery',
    desc: 'Guaranteed transit times, same-day options, priority handling, and digital proof of delivery.',
    href: '/services#express',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    span: 'lg:col-span-2',
  },
  {
    title: 'Warehousing',
    desc: 'Climate-controlled units, 24/7 security with CCTV, inventory management, and pick-and-pack services.',
    href: '/services#warehouse',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>`,
    span: '',
  },
  {
    title: 'Certificates & Documentation',
    desc: 'Certificate of Origin, Phytosanitary certificates, Fumigation certificates, Ad Code and IFSC registration, RODTEP scrip generation.',
    href: '/services#certificates',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="w-7 h-7"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>`,
    span: 'lg:col-span-3',
  },
