---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
---

<section class="py-20 md:py-28 bg-cream">
  <div class="max-w-[1400px] mx-auto px-5 lg:px-8">
    <div
      class="relative rounded-3xl px-8 py-16 md:px-16 md:py-20 overflow-hidden"
      style="background: radial-gradient(ellipse at 88% 15%, rgba(212,98,43,0.10) 0%, transparent 55%), #0C1E35;"
      data-reveal
    >
      <!-- Grid background -->
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(rgba(255,255,255,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 48px 48px;"
      ></div>

      <div class="relative grid grid-cols-1 lg:grid-cols-5 gap-10 items-center">
        <div class="lg:col-span-3">
          <h2 class="font-display font-bold text-white text-3xl md:text-4xl lg:text-5xl tracking-tight leading-[1.05]">
            Ready to move your<br class="hidden md:block" /> next shipment?
          </h2>
          <p class="mt-4 text-white/40 text-lg max-w-[50ch]">
            Get a free consultation and competitive rate quote. Most requests answered within 4 hours.
          </p>
        </div>
        <div class="lg:col-span-2 flex flex-col sm:flex-row lg:flex-col gap-4 lg:items-end">
          <a
            href="/contact"
            class="inline-flex items-center justify-center gap-2 bg-copper text-white font-medium
                   px-8 py-4 rounded-lg hover:bg-copper-600 active:scale-[0.97]
                   transition-all duration-200 shadow-lg shadow-copper/20 text-center"
          >
            Get a Free Quote
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://wa.me/918439312613"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 border border-white/15 text-white font-medium
                   px-8 py-4 rounded-lg hover:bg-white/10 active:scale-[0.97]
                   transition-all duration-200 text-center"
          >
            <WhatsAppIcon class="w-4 h-4" />
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>