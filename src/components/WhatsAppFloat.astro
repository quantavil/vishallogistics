---
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
---

<a
  href="https://wa.me/918439312613"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat on WhatsApp"
  class="fixed bottom-6 right-6 z-30 w-14 h-14 bg-[#25D366] rounded-full flex items-center justify-center
         shadow-lg shadow-[#25D366]/30 hover:scale-110 active:scale-95 transition-transform duration-200"
>
  <!-- Pulse ring -->
  <span class="absolute inset-0 rounded-full bg-[#25D366] animate-pulse-ring"></span>
  <!-- Icon -->
  <WhatsAppIcon class="w-7 h-7 text-white relative z-10" />
</a>